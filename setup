#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
SSH_KEY_PATH="$HOME/.ssh/github_id_ed25519"
SSH_CONFIG_PATH="$HOME/.ssh/config"
SSH_CONFIG_BEGIN="# >>> dotfiles github ssh >>>"
SSH_CONFIG_END="# <<< dotfiles github ssh <<<"
DEFAULT_SSH_KEYS=(id_ed25519 id_ecdsa id_rsa)

WARNINGS=()
GITHUB_KEY_CREATED=0
RUN_HOMEBREW=0
RUN_REMOTE_DEV=0
RUN_GITHUB=0
RUN_SHELL=0
RUN_GIT_CONFIG=0
RUN_VIM=0
RUN_ASDF=0
RUN_NVIM=0
RUN_TMUX=0
RUN_EZA=0
RUN_XCODE=0

log() {
  printf '%s\n' "$*"
}

warn() {
  local message="$1"
  WARNINGS+=("$message")
  printf 'WARNING: %s\n' "$message" >&2
}

usage() {
  cat <<'EOF'
Usage: ./install.sh [SECTION...]

When no section flags are provided, all setup sections run.
When one or more section flags are provided, only those sections run.

Sections:
  --homebrew  Install Homebrew and Brewfile packages
  --remote-dev  Install a minimal remote-dev toolchain and related config
  --github    Configure git identity and GitHub SSH access
  --configs   Run all config-related sections
  --shell     Symlink the shell config files
  --git       Symlink the git config file
  --vim       Symlink the Vim config
  --asdf      Install asdf plugins and their latest versions
  --nvim      Symlink the Neovim config and install lazy.nvim
  --tmux      Symlink tmux config and install TPM
  --eza       Symlink the eza theme config
  --xcode     Install Xcode Command Line Tools on macOS
  --all       Run all sections
  -h, --help  Show this help
EOF
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

enable_all_sections() {
  RUN_HOMEBREW=1
  RUN_GITHUB=1
  RUN_SHELL=1
  RUN_GIT_CONFIG=1
  RUN_VIM=1
  RUN_ASDF=1
  RUN_NVIM=1
  RUN_TMUX=1
  RUN_EZA=1
  RUN_XCODE=1
}

enable_all_config_sections() {
  RUN_SHELL=1
  RUN_GIT_CONFIG=1
  RUN_VIM=1
  RUN_NVIM=1
  RUN_TMUX=1
  RUN_EZA=1
}

print_selected_sections() {
  local sections=()
  local section=""
  local section_list=""

  [[ "$RUN_HOMEBREW" -eq 1 ]] && sections+=("homebrew")
  [[ "$RUN_REMOTE_DEV" -eq 1 ]] && sections+=("remote-dev")
  [[ "$RUN_GITHUB" -eq 1 ]] && sections+=("github")
  [[ "$RUN_SHELL" -eq 1 ]] && sections+=("shell")
  [[ "$RUN_GIT_CONFIG" -eq 1 ]] && sections+=("git")
  [[ "$RUN_VIM" -eq 1 ]] && sections+=("vim")
  [[ "$RUN_ASDF" -eq 1 ]] && sections+=("asdf")
  [[ "$RUN_NVIM" -eq 1 ]] && sections+=("nvim")
  [[ "$RUN_TMUX" -eq 1 ]] && sections+=("tmux")
  [[ "$RUN_EZA" -eq 1 ]] && sections+=("eza")
  [[ "$RUN_XCODE" -eq 1 ]] && sections+=("xcode")

  for section in "${sections[@]}"; do
    if [[ -n "$section_list" ]]; then
      section_list="${section_list}, "
    fi
    section_list="${section_list}${section}"
  done

  log "Running setup sections: $section_list"
}

parse_args() {
  local section_flag_seen=0
  local force_all=0

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --homebrew)
        RUN_HOMEBREW=1
        section_flag_seen=1
        ;;
      --remote-dev)
        RUN_REMOTE_DEV=1
        RUN_GITHUB=1
        RUN_SHELL=1
        RUN_TMUX=1
        section_flag_seen=1
        ;;
      --github)
        RUN_GITHUB=1
        section_flag_seen=1
        ;;
      --configs)
        enable_all_config_sections
        section_flag_seen=1
        ;;
      --shell)
        RUN_SHELL=1
        section_flag_seen=1
        ;;
      --git)
        RUN_GIT_CONFIG=1
        section_flag_seen=1
        ;;
      --vim)
        RUN_VIM=1
        section_flag_seen=1
        ;;
      --asdf)
        RUN_ASDF=1
        section_flag_seen=1
        ;;
      --nvim)
        RUN_NVIM=1
        section_flag_seen=1
        ;;
      --tmux)
        RUN_TMUX=1
        section_flag_seen=1
        ;;
      --eza)
        RUN_EZA=1
        section_flag_seen=1
        ;;
      --xcode)
        RUN_XCODE=1
        section_flag_seen=1
        ;;
      --all)
        force_all=1
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        warn "Unknown option: $1"
        usage >&2
        exit 1
        ;;
    esac

    shift
  done

  if [[ "$force_all" -eq 1 || "$section_flag_seen" -eq 0 ]]; then
    enable_all_sections
  fi
}

ensure_homebrew_env() {
  local brew_bin

  if command_exists brew; then
    return 0
  fi

  for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$brew_bin" ]]; then
      eval "$("$brew_bin" shellenv)"
      return 0
    fi
  done

  return 1
}

install_homebrew() {
  if ensure_homebrew_env; then
    log "Homebrew already installed. Skipping."
    return 0
  fi

  log "Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if ensure_homebrew_env; then
    log "Homebrew installation complete."
    return 0
  fi

  warn "Homebrew installation finished, but 'brew' is still unavailable in this shell."
  return 1
}

brewfile_path() {
  printf '%s' "$REPO_ROOT/Brewfile"
}

remote_dev_brewfile_path() {
  printf '%s' "$REPO_ROOT/Brewfile.remote-dev"
}

brewfile_has_mas_apps() {
  local brewfile="$1"
  grep -Eq '^mas "' "$brewfile"
}

mac_app_store_signed_in() {
  command_exists mas && mas account >/dev/null 2>&1
}

bundled_mas_apps() {
  local brewfile="$1"
  sed -nE 's/^mas "([^"]+)", id: ([0-9]+).*$/\1\t\2/p' "$brewfile"
}

install_mac_app_store_apps() {
  local brewfile="$1"
  local installed_ids=""
  local app_name=""
  local app_id=""

  if [[ "$(uname -s)" != "Darwin" ]]; then
    return 0
  fi

  if ! brewfile_has_mas_apps "$brewfile"; then
    return 0
  fi

  if ! command_exists mas; then
    warn "'mas' is unavailable, so Mac App Store apps were skipped."
    return 0
  fi

  if ! mac_app_store_signed_in; then
    warn "Not signed into the Mac App Store, so Mac App Store apps were skipped."
    return 0
  fi

  installed_ids="$(mas list 2>/dev/null | awk '{print $1}')"

  while IFS=$'\t' read -r app_name app_id; do
    [[ -z "$app_id" ]] && continue

    if printf '%s\n' "$installed_ids" | grep -Fxq "$app_id"; then
      log "Mac App Store app '$app_name' already installed. Skipping."
      continue
    fi

    log "Installing Mac App Store app '$app_name'..."
    if mas install "$app_id"; then
      installed_ids="${installed_ids}"$'\n'"$app_id"
    else
      warn "Failed to install Mac App Store app '$app_name' ($app_id)."
    fi
  done < <(bundled_mas_apps "$brewfile")
}

install_brew_bundle() {
  local brewfile="$1"

  if [[ ! -f "$brewfile" ]]; then
    warn "Brewfile not found at $brewfile."
    return 0
  fi

  log "Installing Homebrew bundle from $brewfile..."
  if ! HOMEBREW_BUNDLE_MAS_SKIP=1 brew bundle install --file "$brewfile" --no-upgrade; then
    warn "Homebrew bundle install failed. Review the Homebrew output above."
    return 0
  fi

  install_mac_app_store_apps "$brewfile"
}

install_homebrew_packages() {
  install_brew_bundle "$(brewfile_path)"
}

install_remote_dev_packages() {
  if ! install_homebrew; then
    warn "Homebrew is unavailable, so remote-dev packages were skipped."
    return 0
  fi

  install_brew_bundle "$(remote_dev_brewfile_path)"
}

prompt_for_value() {
  local prompt="$1"
  local default_value="$2"
  local response=""

  if [[ -n "$default_value" ]]; then
    read -r -p "$prompt [$default_value]: " response
    if [[ -z "$response" ]]; then
      response="$default_value"
    fi
  else
    read -r -p "$prompt: " response
  fi

  printf '%s' "$response"
}

flag_enabled() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON)
      return 0
      ;;
  esac

  return 1
}

git_global_value() {
  git config --global --get "$1" 2>/dev/null || true
}

git_identity_configured() {
  [[ -n "$(git_global_value user.name)" && -n "$(git_global_value user.email)" ]]
}

github_host_entry_present() {
  [[ -f "$SSH_CONFIG_PATH" ]] || return 1
  grep -Eq '^[[:space:]]*Host[[:space:]]+github\.com([[:space:]]|$)' "$SSH_CONFIG_PATH"
}

github_managed_config_present() {
  [[ -f "$SSH_CONFIG_PATH" ]] || return 1
  grep -Fq "$SSH_CONFIG_BEGIN" "$SSH_CONFIG_PATH" || \
    grep -Fq "IdentityFile ~/.ssh/github_id_ed25519" "$SSH_CONFIG_PATH"
}

default_ssh_key_present() {
  local key_name=""

  for key_name in "${DEFAULT_SSH_KEYS[@]}"; do
    if [[ -f "$HOME/.ssh/$key_name" || -f "$HOME/.ssh/$key_name.pub" ]]; then
      return 0
    fi
  done

  return 1
}

github_ssh_setup_present() {
  if [[ -f "$SSH_KEY_PATH" ]] && github_managed_config_present; then
    return 0
  fi

  if github_host_entry_present; then
    return 0
  fi

  if default_ssh_key_present; then
    return 0
  fi

  return 1
}

github_setup_needed() {
  if flag_enabled "${FORCE_GITHUB_SETUP:-}"; then
    return 0
  fi

  [[ -n "${GITHUB_USERNAME:-}" ]] && return 0
  [[ -n "${GITHUB_EMAIL:-}" ]] && return 0

  if ! git_identity_configured; then
    return 0
  fi

  if ! github_ssh_setup_present; then
    return 0
  fi

  return 1
}

configure_git_identity() {
  local existing_email=""
  local existing_username=""
  local github_email=""
  local github_username=""
  local should_prompt=0

  existing_email="$(git_global_value user.email)"
  existing_username="$(git_global_value user.name)"

  github_email="${GITHUB_EMAIL:-$existing_email}"
  github_username="${GITHUB_USERNAME:-$existing_username}"

  if [[ -z "$github_email" || -z "$github_username" ]]; then
    should_prompt=1
  fi

  if [[ $should_prompt -eq 1 && -t 0 && -t 1 ]]; then
    printf '%s\n' "================================================================================"
    printf '%s\n' "                           GitHub Setup Instructions                            "
    printf '%s\n' "================================================================================"
    printf '%s\n' "This script will guide you through setting up your GitHub SSH key and Git config."
    printf '%s\n' "Only missing values will be requested."
    printf '\n'

    if [[ -z "$github_email" ]]; then
      github_email="$(prompt_for_value "Enter your GitHub email address" "$github_email")"
    fi

    if [[ -z "$github_username" ]]; then
      github_username="$(prompt_for_value "Enter your GitHub username" "$github_username")"
    fi

    printf '\n'
  fi

  if [[ -n "$github_username" ]]; then
    if [[ "$existing_username" == "$github_username" ]]; then
      log "Git global user.name already set to '$github_username'. Skipping."
    else
      git config --global user.name "$github_username"
      log "Git global user.name set to '$github_username'."
    fi
  else
    warn "GitHub username is unset. Skipping git user.name configuration."
  fi

  if [[ -n "$github_email" ]]; then
    if [[ "$existing_email" == "$github_email" ]]; then
      log "Git global user.email already set to '$github_email'. Skipping."
    else
      git config --global user.email "$github_email"
      log "Git global user.email set to '$github_email'."
    fi
  else
    warn "GitHub email is unset. Skipping git user.email configuration and SSH key generation."
  fi

  GITHUB_EMAIL="${github_email}"
}

ensure_github_ssh_key() {
  local github_email="${GITHUB_EMAIL:-}"

  GITHUB_KEY_CREATED=0
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"

  if [[ -f "$SSH_KEY_PATH" ]]; then
    log "GitHub SSH key already exists at $SSH_KEY_PATH. Skipping generation."
    return 0
  fi

  if [[ -z "$github_email" ]]; then
    warn "GitHub email is unavailable, so the GitHub SSH key was not generated."
    return 0
  fi

  log "Generating GitHub SSH key..."
  ssh-keygen -t ed25519 -C "$github_email" -f "$SSH_KEY_PATH" -N ""
  GITHUB_KEY_CREATED=1
}

ensure_github_ssh_config() {
  mkdir -p "$HOME/.ssh"
  touch "$SSH_CONFIG_PATH"
  chmod 600 "$SSH_CONFIG_PATH"

  if [[ ! -f "$SSH_KEY_PATH" ]]; then
    warn "GitHub SSH key is missing, so ~/.ssh/config was left unchanged."
    return 0
  fi

  if grep -Fq "$SSH_CONFIG_BEGIN" "$SSH_CONFIG_PATH"; then
    log "Managed GitHub SSH config block already present. Skipping."
    return 0
  fi

  if grep -Fq "IdentityFile ~/.ssh/github_id_ed25519" "$SSH_CONFIG_PATH"; then
    log "GitHub SSH config already references ~/.ssh/github_id_ed25519. Skipping managed block."
    return 0
  fi

  log "Adding managed GitHub SSH config block to $SSH_CONFIG_PATH..."
  printf '\n%s\n' "$SSH_CONFIG_BEGIN" >> "$SSH_CONFIG_PATH"
  printf '%s\n' "Host github.com" >> "$SSH_CONFIG_PATH"
  printf '%s\n' "  HostName github.com" >> "$SSH_CONFIG_PATH"
  printf '%s\n' "  User git" >> "$SSH_CONFIG_PATH"
  printf '%s\n' "  IdentityFile ~/.ssh/github_id_ed25519" >> "$SSH_CONFIG_PATH"
  printf '%s\n' "  IdentitiesOnly yes" >> "$SSH_CONFIG_PATH"
  printf '%s\n' "$SSH_CONFIG_END" >> "$SSH_CONFIG_PATH"
}

add_github_key_to_agent() {
  if [[ ! -f "$SSH_KEY_PATH" ]]; then
    return 0
  fi

  if ! command_exists ssh-add; then
    log "ssh-add is unavailable. Skipping automatic ssh-agent setup."
    return 0
  fi

  if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
    log "ssh-agent is not available in this shell. Skipping automatic key add."
    return 0
  fi

  if ssh-add "$SSH_KEY_PATH" >/dev/null 2>&1; then
    log "GitHub SSH key added to ssh-agent."
    return 0
  fi

  warn "Could not add $SSH_KEY_PATH to ssh-agent automatically."
}

print_github_key_instructions() {
  printf '%s\n' "================================================================================"
  printf '%s\n' "IMPORTANT: Add your SSH public key to GitHub:"
  printf '%s\n' "          Public key path: ${SSH_KEY_PATH}.pub"

  if command_exists gh; then
    printf '%s\n' "          Authenticate GitHub CLI: gh auth login"
    printf '%s\n' "          Upload with GitHub CLI: gh ssh-key add ${SSH_KEY_PATH}.pub --title \"$(hostname)-$(date +%F)\""
  fi

  if command_exists pbcopy; then
    printf '%s\n' "          Copy on macOS: pbcopy < ${SSH_KEY_PATH}.pub"
  elif command_exists wl-copy; then
    printf '%s\n' "          Copy on Wayland: wl-copy < ${SSH_KEY_PATH}.pub"
  elif command_exists xclip; then
    printf '%s\n' "          Copy on X11: xclip -selection clipboard < ${SSH_KEY_PATH}.pub"
  else
    printf '%s\n' "          Print the key: cat ${SSH_KEY_PATH}.pub"
  fi

  printf '%s\n' "================================================================================"
}

configure_github() {
  if ! github_setup_needed; then
    log "GitHub identity and SSH access already appear configured. Skipping."
    return 0
  fi

  if ! git_identity_configured || [[ -n "${GITHUB_USERNAME:-}" || -n "${GITHUB_EMAIL:-}" ]]; then
    configure_git_identity
  else
    GITHUB_EMAIL="$(git_global_value user.email)"
    log "Git global identity already configured. Skipping."
  fi

  if github_ssh_setup_present && ! flag_enabled "${FORCE_GITHUB_SETUP:-}"; then
    log "GitHub SSH access already appears configured. Skipping."
    return 0
  fi

  ensure_github_ssh_key
  ensure_github_ssh_config
  add_github_key_to_agent

  if [[ "$GITHUB_KEY_CREATED" -eq 1 && -f "${SSH_KEY_PATH}.pub" ]]; then
    print_github_key_instructions
  fi
}

ensure_symlink() {
  local source_path="$1"
  local target_path="$2"
  local current_target=""

  mkdir -p "$(dirname "$target_path")"

  if [[ -L "$target_path" ]]; then
    current_target="$(readlink "$target_path")"
    if [[ "$current_target" == "$source_path" ]]; then
      log "Symlink already correct: $target_path"
      return 0
    fi

    rm "$target_path"
    ln -s "$source_path" "$target_path"
    log "Updated symlink: $target_path -> $source_path"
    return 0
  fi

  if [[ -e "$target_path" ]]; then
    warn "Skipping $target_path because it exists and is not a symlink."
    return 0
  fi

  ln -s "$source_path" "$target_path"
  log "Created symlink: $target_path -> $source_path"
}

ensure_repo_submodule() {
  local submodule_path="$1"

  if [[ -d "$REPO_ROOT/$submodule_path/.git" || -f "$REPO_ROOT/$submodule_path/.git" ]]; then
    return 0
  fi

  log "Initializing submodule: $submodule_path"
  git -C "$REPO_ROOT" submodule sync -- "$submodule_path"
  git -C "$REPO_ROOT" submodule update --init -- "$submodule_path"
}

symlink_shell_configs() {
  ensure_repo_submodule "config_files/ohmyzsh"
  ensure_symlink "$REPO_ROOT/config_files/zshrc" "$HOME/.zshrc"
  ensure_symlink "$REPO_ROOT/config_files/p10k.zsh" "$HOME/.p10k.zsh"
  ensure_symlink "$REPO_ROOT/config_files/aliases.zsh" "$HOME/.aliases.zsh"
  ensure_symlink "$REPO_ROOT/config_files/zshrc_env" "$HOME/.zshrc_env"
  ensure_symlink "$REPO_ROOT/config_files/nvm.zsh" "$HOME/.nvm.zsh"
}

symlink_git_config() {
  ensure_symlink "$REPO_ROOT/config_files/gitconfig" "$HOME/.gitconfig"
}

symlink_vim_config() {
  ensure_symlink "$REPO_ROOT/config_files/vimrc" "$HOME/.vimrc"
  ensure_symlink "$REPO_ROOT/vim" "$HOME/.vim"
}

symlink_nvim_config() {
  ensure_repo_submodule "nvim"
  ensure_symlink "$REPO_ROOT/nvim" "$HOME/.config/nvim"
}

symlink_tmux_config() {
  ensure_repo_submodule "config_files/ohmytmux"
  ensure_symlink "$REPO_ROOT/config_files/ohmytmux/.tmux.conf" "$HOME/.tmux.conf"
  ensure_symlink "$REPO_ROOT/config_files/tmux.conf.local" "$HOME/.tmux.conf.local"
}

symlink_eza_config() {
  ensure_symlink "$REPO_ROOT/config_files/eza/themes/tokyonight.yml" "$HOME/Library/Application Support/eza/theme.yml"
}

asdf_plugin_installed() {
  local plugin_name="$1"
  asdf plugin list 2>/dev/null | grep -Fxq "$plugin_name"
}

asdf_has_installed_versions() {
  local plugin_name="$1"
  local installed_versions=""

  installed_versions="$(asdf list "$plugin_name" 2>/dev/null || true)"
  [[ -n "${installed_versions//[[:space:]]/}" ]]
}

ensure_asdf_plugin() {
  local plugin_name="$1"
  local plugin_url="$2"

  if asdf_plugin_installed "$plugin_name"; then
    log "asdf plugin '$plugin_name' already added. Skipping."
    return 0
  fi

  log "Adding asdf plugin '$plugin_name'..."
  asdf plugin add "$plugin_name" "$plugin_url"
}

ensure_asdf_version() {
  local plugin_name="$1"
  local latest_version=""

  if asdf_has_installed_versions "$plugin_name"; then
    log "asdf '$plugin_name' already has installed versions. Skipping."
    return 0
  fi

  latest_version="$(asdf latest "$plugin_name" 2>/dev/null || true)"
  if [[ -z "$latest_version" ]]; then
    warn "Could not determine the latest version for asdf plugin '$plugin_name'."
    return 0
  fi

  log "Installing asdf '$plugin_name' version '$latest_version'..."
  asdf install "$plugin_name" "$latest_version"
}

install_asdf_libraries() {
  if ! command_exists asdf; then
    warn "asdf is not available on PATH. Skipping asdf plugin installation."
    return 0
  fi

  ensure_asdf_plugin ruby https://github.com/asdf-vm/asdf-ruby.git
  ensure_asdf_version ruby

  ensure_asdf_plugin nodejs https://github.com/asdf-vm/asdf-nodejs.git
  ensure_asdf_version nodejs
}

ensure_git_clone() {
  local repository_url="$1"
  local destination_path="$2"
  shift 2

  mkdir -p "$(dirname "$destination_path")"

  if [[ -d "$destination_path/.git" || -f "$destination_path/.git" ]]; then
    log "Git checkout already exists at $destination_path. Skipping clone."
    return 0
  fi

  if [[ -e "$destination_path" ]]; then
    warn "Skipping clone into $destination_path because the path exists and is not a git checkout."
    return 0
  fi

  log "Cloning $repository_url into $destination_path..."
  git clone "$@" "$repository_url" "$destination_path"
}

install_nvim_plugin_manager() {
  ensure_git_clone \
    https://github.com/folke/lazy.nvim.git \
    "$HOME/.local/share/nvim/lazy/lazy.nvim" \
    --filter=blob:none \
    --branch=stable
}

install_tmux_plugin_manager() {
  ensure_git_clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
}

install_xcode_cli() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    log "Not running on macOS. Skipping Xcode Command Line Tools installation."
    return 0
  fi

  if xcode-select -p >/dev/null 2>&1; then
    log "Xcode Command Line Tools already installed. Skipping."
    return 0
  fi

  log "Installing Xcode Command Line Tools..."
  xcode-select --install
}

print_summary() {
  printf '\n%s\n' "================================================================================"
  printf '%s\n' "IMPORTANT: Please review README.md for any remaining manual steps:"
  printf '%s\n' "           $REPO_ROOT/README.md"
  printf '%s\n' "================================================================================"

  if [[ "${#WARNINGS[@]}" -eq 0 ]]; then
    return 0
  fi

  printf '\n%s\n' "Completed with warnings:"
  local warning=""
  for warning in "${WARNINGS[@]}"; do
    printf '  - %s\n' "$warning"
  done
}

main() {
  parse_args "$@"
  print_selected_sections

  if [[ "$RUN_HOMEBREW" -eq 1 ]]; then
    install_homebrew
    install_homebrew_packages
  fi

  if [[ "$RUN_REMOTE_DEV" -eq 1 ]]; then
    install_remote_dev_packages
  fi

  if [[ "$RUN_GITHUB" -eq 1 ]]; then
    configure_github
  fi

  if [[ "$RUN_SHELL" -eq 1 ]]; then
    symlink_shell_configs
  fi

  if [[ "$RUN_GIT_CONFIG" -eq 1 ]]; then
    symlink_git_config
  fi

  if [[ "$RUN_VIM" -eq 1 ]]; then
    symlink_vim_config
  fi

  if [[ "$RUN_ASDF" -eq 1 ]]; then
    install_asdf_libraries
  fi

  if [[ "$RUN_NVIM" -eq 1 ]]; then
    symlink_nvim_config
    install_nvim_plugin_manager
  fi

  if [[ "$RUN_TMUX" -eq 1 ]]; then
    symlink_tmux_config
    install_tmux_plugin_manager
  fi

  if [[ "$RUN_EZA" -eq 1 ]]; then
    symlink_eza_config
  fi

  if [[ "$RUN_XCODE" -eq 1 ]]; then
    install_xcode_cli
  fi

  print_summary
}

main "$@"
